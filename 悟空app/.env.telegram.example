TELEGRAM_BOT_TOKEN=123456789:replace_with_botfather_token
TELEGRAM_CHAT_ID=replace_with_your_chat_id

# Optional: enables /ask, /codex, and /codel commands.
OPENAI_API_KEY=sk-replace_with_openai_api_key
# Or use a Codex-compatible API key name.
CODEX_API_KEY=sk-replace_with_codex_api_key
WUKONG_OPENAI_MODEL=gpt-4.1-mini

# Optional: push interval. Default is 60 seconds.
WUKONG_PUSH_INTERVAL_SECONDS=60
