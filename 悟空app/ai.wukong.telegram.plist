<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>ai.wukong.telegram</string>
	<key>ProgramArguments</key>
	<array>
		<string>/usr/bin/python3</string>
		<string>/Users/wangbo/.hermes/wukong_telegram/start_wukong_telegram.py</string>
	</array>
	<key>WorkingDirectory</key>
	<string>/Users/wangbo/.hermes/wukong_telegram</string>
	<key>RunAtLoad</key>
	<true/>
	<key>StartInterval</key>
	<integer>300</integer>
	<key>KeepAlive</key>
	<dict>
		<key>SuccessfulExit</key>
		<false/>
	</dict>
	<key>StandardOutPath</key>
	<string>/Users/wangbo/.hermes/wukong_telegram/wukong_telegram_launch.log</string>
	<key>StandardErrorPath</key>
	<string>/Users/wangbo/.hermes/wukong_telegram/wukong_telegram_launch.error.log</string>
</dict>
</plist>
